# NextE dev env — 复制为 scripts/dev.env（gitignored）并按需修改。
# dev.sh 会自动 source；手动调 sign.py 前先 `source scripts/dev.env`。
# 签名物料与 V2Next 共享（账号级调试证书），避免撞 AGC 调试证书配额。

# 屏幕保活时长（hdc 控制设备时使用）
export SCREEN_OFF_TIMEOUT_MS=13600000

# ── HarmonyOS 调试签名（账号级共享） ────────────────────────────────────────
# 物料目录结构:
#   $HARMONY_DEBUG_DIR/
#     ├── debug.p12                         keystore（含密钥对）
#     ├── debug.csr                         CSR
#     ├── ${HARMONY_DEBUG_CERT_NAME}.cer    AGC 签发的账号级 cert
#     └── profiles/
#         └── <bundleId>.p7b                per-project profile（按 bundleId 单独签发）
#
# HARMONY_DEBUG_KS_ALIAS / KS_PWD 必须与 keystore 内部 alias/密码一致。
# 签名物料锚定真实用户 home（worker 可能用 sandbox HOME，不应改变物料路径）。
export V2NEXT_REAL_HOME="${V2NEXT_REAL_HOME:-$HOME}"
export HARMONY_DEBUG_DIR="${V2NEXT_REAL_HOME}/.config/harmony/debug-signing"
export HARMONY_DEBUG_CERT_NAME="ohos-D"
export HARMONY_DEBUG_KS_ALIAS="ohos"
export HARMONY_DEBUG_KS_PWD="hw123456"

# 项目级 profile（per-bundleId，AGC 不限制 profile 数）
export HARMONY_DEBUG_PROFILE="${HARMONY_DEBUG_DIR}/profiles/com.erosteam.nexte.p7b"

# 应用 bundleId
export NEXTE_BUNDLE="com.erosteam.nexte"

# 非交互签名（CI / headless）：缺签名物料时直接报错，不触发浏览器登录。
# 留空表示允许交互式签发 Profile（首次签发需要）。
# export NEXTE_SIGN_NONINTERACTIVE=1
