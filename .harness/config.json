{
  "projectType": "custom",
  "language": "zh",
  "verificationMode": "strict",
  "buildCmd": "bash dev.sh --build-only",
  "testCmd": "node scripts/test_v1_decorator_inventory_contract.mjs",
  "gates": [
    {
      "name": "claude-md-budget",
      "command": "test ! -f CLAUDE.md || test \"$(wc -l < CLAUDE.md)\" -le 200 || { echo 'CLAUDE.md exceeds 200 lines — move detail into docs/'; exit 1; }",
      "blocking": false
    },
    {
      "name": "v1-decorator-inventory",
      "command": "node scripts/test_v1_decorator_inventory_contract.mjs",
      "blocking": true
    },
    {
      "name": "version-consistency",
      "command": "node scripts/test_version_consistency_contract.mjs",
      "blocking": true
    },
    {
      "name": "secret-safety",
      "command": "node scripts/test_secret_safety_contract.mjs",
      "blocking": true
    },
    {
      "name": "selector-reload-preserves-content",
      "command": "node scripts/test_selector_reload_preserves_content_contract.mjs",
      "blocking": true
    },
    {
      "name": "error-classification",
      "command": "node scripts/test_error_classification_contract.mjs",
      "blocking": true
    },
    {
      "name": "i18n-duplicates",
      "command": "python3 scripts/check_i18n_duplicates.py",
      "blocking": true
    },
    {
      "name": "layering",
      "command": "harness-check-layering",
      "blocking": true
    },
    {
      "name": "doc-links",
      "command": "harness-doc-links",
      "blocking": true
    },
    {
      "name": "plan-dod",
      "command": "harness-check-plan-dod",
      "blocking": true
    }
  ],
  "layeringRules": [
    {
      "scope": "shared/**/*.ets",
      "forbidden": "from\\s+['\"](home|gallery|search|reader|download|user|settings)['\"]",
      "message": "shared 是零依赖叶子层,禁止反向依赖 feature/* 或 entry;需要共享的逻辑应下沉到 shared 内部,而不是从 feature 反向引入。"
    },
    {
      "scope": "feature/**/*.ets",
      "forbidden": "from\\s+['\"](home|gallery|search|reader|download|user|settings)['\"]",
      "message": "feature 模块之间禁止互相 import(只能依赖 shared);要复用就把代码下沉到 shared,跨 feature 协作交由 entry 编排。"
    }
  ],
  "plan": {
    "dir": "docs/plans",
    "codeGlob": "",
    "statusField": "status",
    "completedValue": "completed",
    "checklistRegex": "^- \\[ \\]"
  },
  "docs": {
    "scanRoots": [
      "docs"
    ],
    "architecturePath": "docs/architecture.md",
    "keyDocs": [
      {
        "path": "docs/architecture.md",
        "note": "模块边界与数据流(feature/* → shared,entry 编排)"
      },
      {
        "path": "docs/eh-integration-contract.md",
        "note": "EH 网络/解析契约与魔法常量"
      },
      {
        "path": "docs/roadmap.md",
        "note": "里程碑路线(M0/M1/M3…)"
      },
      {
        "path": "AGENTS.md",
        "note": "agent 指南索引(docs/agent-guides/)"
      }
    ]
  },
  "metrics": [
    {
      "name": "completed-plans",
      "glob": "docs/plans/completed/*.md",
      "exclude": "gitkeep"
    },
    {
      "name": "contract-tests",
      "glob": "scripts/test_*_contract.mjs"
    }
  ],
  "loopDetection": {
    "threshold": 5
  },
  "evaluator": {
    "enabled": false
  }
}
