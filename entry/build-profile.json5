{
  "apiType": "stageMode",
  "buildOption": {
    "sourceOption": {
      "workers": [
        "./src/main/ets/workers/ReaderMindSporeSuperResolutionWorker.ets"
      ]
    }
  },
  "buildOptionSet": [
    {
      "name": "debug",
      "debuggable": true
    },
    {
      "name": "release",
      "debuggable": false,
      "nativeLib": {
        "filter": {
          "excludes": ["**/x86_64/**"]
        }
      }
    }
  ],
  "targets": [
    {
      "name": "default",
      "runtimeOS": "HarmonyOS"
    },
    {
      "name": "ohosTest",
      "runtimeOS": "HarmonyOS"
    }
  ]
}
